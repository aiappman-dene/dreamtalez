# Production deployment environment variables
# Copy this file to your deployment provider's secret manager or use it as a template
# when provisioning Render / cloud environment variables.

NODE_ENV=production
PORT=3001

# Claude / Anthropic production API key.
ANTHROPIC_API_KEY=sk-ant-your-production-key
# CLAUDE_API_KEY=sk-ant-your-production-key

# Require authenticated Firebase users for /generate and /polish in production.
REQUIRE_AUTH_FOR_AI_ROUTES=true

# Production origins: must include your Render app URL and any custom domains.
ALLOWED_ORIGINS=https://dreamtalez.onrender.com,https://www.dreamtalez.com

# Firebase Admin configuration for production.
# Provide either GOOGLE_APPLICATION_CREDENTIALS or the service-account key triple.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Stripe production credentials (optional, but if set then webhook signing secret is required).
STRIPE_SECRET=sk_live_your-stripe-secret-key-here
STRIPE_PRICE_SUBSCRIPTION=price_live_subscription
STRIPE_PRICE_ONEOFF=price_live_oneoff
STRIPE_PRICE_PACK=price_live_pack
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Strongly recommended production base URL and health / webhook origin.
BASE_URL=https://dreamtalez.onrender.com
RENDER_EXTERNAL_URL=https://dreamtalez.onrender.com

# Feature toggles
USE_FULL_AI_PIPELINE=false
USE_OPUS_BLUEPRINT=false

# Optional allowlist for developer or support accounts. Leave blank in production
# unless you intentionally want a small set of bypass accounts.
DEVELOPER_EMAILS=

# Android Digital Asset Links fingerprint for release builds.
ANDROID_SHA256_FINGERPRINT=AA:BB:CC:...:ZZ
