# Local development environment variables
# Copy this file to .env and fill in your local values.

NODE_ENV=development
PORT=3001

# Claude / Anthropic API key for local testing.
# Use a development key, not a production key.
ANTHROPIC_API_KEY=sk-ant-your-dev-key
# CLAUDE_API_KEY=sk-ant-your-dev-key

# By default, local dev does not require auth on AI routes.
REQUIRE_AUTH_FOR_AI_ROUTES=false

# Allowed origins for local dev.
ALLOWED_ORIGINS=http://localhost:3000

# Firebase Admin configuration for local backend token verification.
# Use either a service account JSON via GOOGLE_APPLICATION_CREDENTIALS,
# or the project/client/email/key triple below.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Stripe test credentials (optional).
STRIPE_SECRET=sk_test_your-stripe-secret-key-here
STRIPE_PRICE_SUBSCRIPTION=price_test_subscription
STRIPE_PRICE_ONEOFF=price_test_oneoff
STRIPE_PRICE_PACK=price_test_pack
STRIPE_WEBHOOK_SECRET=whsec_test_webhook-signing-secret

# App URL used for Stripe checkout redirect URLs.
BASE_URL=http://localhost:3000

# Optional local runtime or deployment hints.
RENDER_EXTERNAL_URL=http://localhost:3001

# Optional feature toggles.
USE_FULL_AI_PIPELINE=false
USE_OPUS_BLUEPRINT=false

# Optional developer allowlist for bypass accounts.
DEVELOPER_EMAILS=

# Optional Android Digital Asset Links fingerprint for local validation.
ANDROID_SHA256_FINGERPRINT=
