{
  "appId": "com.dreamtalez.app",
  "appName": "DreamTalez",
  "webDir": "public",
  "server": {
    "url": "https://dreamtalez.onrender.com",
    "cleartext": false
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "ios": {
    "scheme": "DreamTalez",
    "contentInset": "always",
    "allowsLinkPreview": false,
    "handleApplicationNotifications": false,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0b1f3a",
      "showSpinner": false
    }
  }
}
