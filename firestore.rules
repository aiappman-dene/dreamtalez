rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Stories are persisted client-side (localStorage / IndexedDB).
    // Collection is locked — re-enable with uid-scoping if server-side
    // story persistence is added in future.
    match /stories/{storyId} {
      allow read, write: if false;
    }

    // Job records (created by the server when a /generate request starts).
    // The owning user can poll their own jobs; nobody else can read or
    // mutate them. The server uses Admin SDK which bypasses these rules.
    match /jobs/{jobId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // Stripe event deduplication records — server-only via Admin SDK.
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // Guest one-off purchase claim records — server-only via Admin SDK.
    match /guestOneoffClaims/{sessionId} {
      allow read, write: if false;
    }

    // Per-user persistent rate limit windows — server-only via Admin SDK.
    match /userRateLimits/{userId} {
      allow read, write: if false;
    }

    // Per-user generation lock records — server-only via Admin SDK.
    match /generationLocks/{userId} {
      allow read, write: if false;
    }
  }
}
