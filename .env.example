# DreamTalez Environment Configuration
# Copy this file to .env and fill in your values

# Claude / Anthropic API key (required)
# Use either variable name. ANTHROPIC_API_KEY is the canonical one in this repo,
# but CLAUDE_API_KEY is also accepted so local tools can share the same secret.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_API_KEY=sk-ant-your-key-here

# Server
PORT=3000
NODE_ENV=development

# AI pipeline profile: lean = 2 Anthropic calls max, full = full multi-pass pipeline
AI_PIPELINE_PROFILE=lean

# Require a logged-in Firebase user before allowing /generate and /polish.
# Set true once one of the Firebase Admin options below is configured.
REQUIRE_AUTH_FOR_AI_ROUTES=false

# CORS — comma-separated allowed origins.
# Production should be your exact HTTPS app origins only, for example:
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=http://localhost:3000

# Firebase Admin configuration for backend token verification.
# Supported options:
# 1. GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# 2. FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
# 3. FIREBASE_PROJECT_ID only (sufficient for verifyIdToken on /generate and /polish)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Stripe (payments)
# Get these from https://dashboard.stripe.com/apikeys and your product's price ID
STRIPE_SECRET=sk_live_your-stripe-secret-key-here
STRIPE_PRICE_ID=price_your-stripe-price-id-here
BASE_URL=https://dreamtalez.web.app

# SSL (production only)
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
