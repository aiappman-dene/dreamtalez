# Bedtalez Environment Configuration
# Use one of the examples below as your starting point:
#   local.env.example  → local development
#   deploy.env.example → production/deployment
# Copy the file you need to .env and fill in your values.

# Claude / Anthropic API key (required)
# Use either variable name. ANTHROPIC_API_KEY is the canonical one in this repo,
# but CLAUDE_API_KEY is also accepted so local tools can share the same secret.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_API_KEY=sk-ant-your-key-here

# Server
PORT=3001
NODE_ENV=development

# AI pipeline profile: lean = 2 Anthropic calls max, full = full multi-pass pipeline
AI_PIPELINE_PROFILE=lean

# Require a logged-in Firebase user before allowing /generate and /polish.
# Set true once one of the Firebase Admin options below is configured.
REQUIRE_AUTH_FOR_AI_ROUTES=false

# Enforce Firebase App Check (reCAPTCHA Enterprise) on AI routes.
# Set true in production once bedtalez.onrender.com is registered in reCAPTCHA Enterprise.
# Leave false (or unset) in local dev — reCAPTCHA is skipped on localhost automatically.
REQUIRE_APP_CHECK=false

# CORS — comma-separated allowed origins.
# Production should be your exact HTTPS app origins only, for example:
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=http://localhost:3000

# Firebase Admin configuration for backend token verification.
# Supported options:
# 1. GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# 2. FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
# 3. FIREBASE_PROJECT_ID only (sufficient for verifyIdToken on /generate and /polish)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Stripe (payments)
# Get these from https://dashboard.stripe.com/apikeys and your product's price IDs
STRIPE_SECRET=sk_live_your-stripe-secret-key-here
STRIPE_PRICE_SUBSCRIPTION=price_your-subscription-price-id   # £4.99/month recurring
STRIPE_PRICE_ONEOFF=price_your-one-off-price-id              # £0.99 one-time
STRIPE_PRICE_PACK=price_your-pack-price-id                   # £1.99 for 10 stories
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret       # from Stripe → Developers → Webhooks
BASE_URL=https://bedtalez.web.app

# Optional comma-separated allowlist for developer payment bypass accounts.
# Leave empty in production unless you intentionally want audited free-access accounts.
DEVELOPER_EMAILS=

# Android Digital Asset Links (assetlinks.json)
# Get this from: keytool -list -v -keystore bedtalez-release.jks -alias bedtalez
# Use the "SHA256:" line, colon-separated hex pairs, e.g. AA:BB:CC:...
ANDROID_SHA256_FINGERPRINT=

# SSL (production only)
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
